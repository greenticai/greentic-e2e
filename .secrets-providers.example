# Provider E2E Test Secrets
# Copy this file to .secrets-providers and fill in the values
# Only fill in secrets for providers you want to test

# =============================================================================
# GENERAL
# =============================================================================
PUBLIC_BASE_URL=https://your-tunnel.ngrok-free.app

# =============================================================================
# MESSAGING PROVIDERS
# =============================================================================

# Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Slack (api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_APP_ID=A07XXXXXX
SLACK_CONFIGURATION_TOKEN=xoxe.xoxp-xxx

# Microsoft Teams (Azure Bot Service)
MS_BOT_APP_ID=00000000-0000-0000-0000-000000000000
MS_BOT_APP_PASSWORD=your-client-secret

# Webex (developer.webex.com)
WEBEX_BOT_TOKEN=your-webex-bot-token

# WhatsApp (developers.facebook.com)
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
WHATSAPP_TOKEN=your-whatsapp-access-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# Email (Microsoft Graph)
EMAIL_FROM_ADDRESS=bot@yourdomain.com
GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_CLIENT_SECRET=your-client-secret
MS_GRAPH_REFRESH_TOKEN=your-refresh-token

# WebChat (Direct Line)
# Generate with: openssl rand -hex 32
WEBCHAT_JWT_SIGNING_KEY=your-jwt-signing-key-hex

# =============================================================================
# EVENT PROVIDERS
# =============================================================================

# SendGrid (sendgrid.com)
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Twilio (twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567

# =============================================================================
# TENANT (for gtc install --tenant)
# =============================================================================
GREENTIC_TENANT=3point
GREENTIC_TENANT_TOKEN=your-tenant-token
