      "random": true
    }
  },
  "config_schema": {
    "additionalProperties": false,
    "properties": {},
    "required": [],
    "type": "object"
  },
  "default_operation": "probe",
  "describe_export": "describe",
  "dev_flows": {
    "default": {
      "format": "flow-ir-json",
      "graph": {
        "edges": [
          {
            "from": "start",
            "to": "end"
