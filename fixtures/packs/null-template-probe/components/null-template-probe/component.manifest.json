            "type": "string"
          },
          "title_i18n_key": {
            "type": "string"
          }
        },
        "required": [
          "mode",
          "fields"
        ],
        "type": "object"
      }
    },
    {
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": true,
        "properties": {
          "answers": {
            "type": "object"
          },
          "current_config": {
            "type": "object"
          },
          "mode": {
            "type": "string"
